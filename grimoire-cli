});

function serializeLicense(license: License) {
  return {
    id: license.id, trial: license.trial, activationMethod: license.activationMethod,
    product: license.product,
    issuedAt: license.issuedAt?.toISOString?.() ?? license.issuedAt,
    issuedTo: license.issuedTo,
    expiresAt: license.expiresAt?.toISOString?.() ?? license.expiresAt ?? null,
    validatedAt: license.validatedAt?.toISOString?.() ?? license.validatedAt,
  };
}

async function cmdLicenseActivate(): Promise<CommandResult> {
  try {
    const response = await licensing.client.requestActivation();
    const requestData = Buffer.from(JSON.stringify(response)).toString("base64");
    return { ok: true, browser: response.browser, requestData };
  } catch (e: any) {
    return { ok: false, error: e instanceof MoonbaseError ? `${e.title}: ${e.detail ?? ""}` : e.message };
  }
}

async function cmdLicensePoll(args: string[]): Promise<CommandResult> {
  const { positional } = parseArgs(args);
  if (!positional[0]) return { ok: false, error: "poll requires requestData argument" };
  try {
    const request: ActivationRequestResponse = JSON.parse(Buffer.from(positional[0], "base64").toString("utf8"));
    const license = await licensing.client.getRequestedActivation(request);
    if (license) {
      await licenseStore.storeLocalLicense(license);
      return { ok: true, activated: true, license: serializeLicense(license) };
    }
    return { ok: true, activated: false };
  } catch (e: any) {
    return { ok: false, error: e instanceof MoonbaseError ? `${e.title}: ${e.detail ?? ""}` : e.message };
  }
}

async function cmdLicenseValidate(): Promise<CommandResult> {
  try {
    const license = await licenseStore.loadLocalLicense();
    if (!license) return { ok: true, valid: false, reason: "no_license" };
    const updated = await licensing.client.validateLicense(license);
    await licenseStore.storeLocalLicense(updated);
    return { ok: true, valid: true, license: serializeLicense(updated) };
  } catch (e: any) {
    if (e instanceof MoonbaseError) {
      return { ok: true, valid: false, reason: e.type ?? "validation_failed", detail: `${e.title}: ${e.detail ?? ""}` };
    }
    return { ok: false, error: e.message };
  }
}

async function cmdLicenseStatus(): Promise<CommandResult> {
  try {
    const license = await licenseStore.loadLocalLicense();
    if (!license) return { ok: true, active: false };
    return { ok: true, active: true, license: serializeLicense(license) };
  } catch (e: any) {
    return { ok: false, error: e instanceof MoonbaseError ? `${e.title}: ${e.detail ?? ""}` : e.message };
  }
}

// ─── Command dictionary ─────────────────────────────────────────────────────

const COMMANDS: CommandDict = {
  // NeueBun builtins (os-info, home-dir, ensure-dir, remove-dir, open-file, open-folder)
  ...builtinCommands,
  // Override os-info with grimoire-specific version (adds configDir)
  "os-info": cmdOsInfo,
  // Grimoire-specific commands
  "launch-terminal": cmdLaunchTerminal,
  "run-entity": cmdRunEntity,
  "check-claude": cmdCheckClaude,
  "check-version": cmdCheckVersion,
  "git-init": cmdGitInit,
  "git-commit": cmdGitCommit,
  "git-log": cmdGitLog,
  "git-restore": cmdGitRestore,
  "git-pull": cmdGitPull,
  "git-push": cmdGitPush,
  "git-remote": cmdGitRemote,
  "git-remove": cmdGitRemove,
  "docker-discover": cmdDockerDiscover,
  "cron-start": cmdCronStart,
  "cron-stop": cmdCronStop,
  "cron-status": cmdCronStatus,
  "cron-log": cmdCronLog,
  "cron-clean": cmdCronClean,
  "kill-terminals": cmdKillTerminals,
  "kill-crons": cmdKillCrons,
  "license-activate": cmdLicenseActivate,
  "license-poll": cmdLicensePoll,
  "license-validate": cmdLicenseValidate,
  "license-status": cmdLicenseStatus,
};

// ─── Entry point: CLI or server mode ────────────────────────────────────────

const firstArg = process.argv[2];

if (firstArg === "--serve") {
  const port = parseInt(process.argv[3] || "0", 10);
  createServer(COMMANDS, { port });
} else {
  createCli(COMMANDS).run();
}
